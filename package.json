{
  "name": "env-from-example",
  "version": "1.0.0",
  "description": "Interactive and non-interactive CLI to set up .env from .env.example",
  "type": "module",
  "main": "dist/env-from-example.js",
  "bin": {
    "env-from-example": "dist/env-from-example.js"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
